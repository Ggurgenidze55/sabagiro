# Copy to .env.local and fill Railway Postgres URL (public URL + ?sslmode=require)

DATABASE_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway?sslmode=require"

AUTH_SECRET="run: openssl rand -base64 32"

APP_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Optional email
# RESEND_API_KEY=
# EMAIL_FROM="Sabagiro <tickets@sabagiro.test>"

# Payments (lib/payments — independent of LariPay)
# Without TBC credentials, checkout uses test simulator at /payment/test
SABAGIRO_PUBLIC_URL="http://localhost:3001"
# SABAGIRO_PAYMENTS_TEST_MODE=true
# TBC_ENV=sandbox
# TBC_CLIENT_ID=
# TBC_CLIENT_SECRET=
# TBC_API_KEY=
# TBC_WEBHOOK_SECRET=
