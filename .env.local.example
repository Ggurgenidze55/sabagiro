# Copy to .env.local and fill Railway Postgres URL (public URL + ?sslmode=require)

DATABASE_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway?sslmode=require"

AUTH_SECRET="run: openssl rand -base64 32"

APP_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Email (Resend) — registration, tickets, password reset, verification
# RESEND_API_KEY=re_...
# EMAIL_FROM="Sabagiro <tickets@sabagiro.ge>"

# Payments — Flitt (https://docs.flitt.com/) — see docs/PAYMENTS-FLITT.md
SABAGIRO_PUBLIC_URL="http://localhost:3001"
# Without Flitt creds → test simulator at /payment/test
# SABAGIRO_PAYMENTS_TEST_MODE=true
# FLITT_MERCHANT_ID=1549901
# FLITT_SECRET_KEY=test
# FLITT_API_ORIGIN=https://pay.flitt.com
