generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum TicketStatus {
  VALID
  USED
  CANCELLED
}

enum TicketSource {
  PURCHASE
  ADMIN
  FREE
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

enum PaymentProvider {
  TBC
  TEST
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  phone              String
  passwordHash       String
  firstName          String
  lastName           String
  personalId         String
  facebookUrl        String             @default("")
  instagramUrl       String             @default("")
  verificationStatus VerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  role                 Role               @default(USER)
  ticketLimitPerEvent  Int                @default(1)
  freeTicketsEnabled   Boolean            @default(false)
  freeTicketsQuota     Int                @default(0)
  freeTicketsUsed      Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  tickets              Ticket[]           @relation("TicketOwner")
  ticketsCreated       Ticket[]           @relation("TicketCreatedBy")
  orders               Order[]
  passwordResetTokens  PasswordResetToken[]

  @@index([verificationStatus])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    OrderStatus @default(PENDING)
  totalGel  Int
  currency  String      @default("GEL")
  expiresAt DateTime?
  paidAt    DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  items     OrderItem[]
  payments  Payment[]

  @@index([userId, status])
  @@index([status, createdAt])
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productSlug String
  productName String
  quantity    Int
  unitPrices  Json
  tierLabels  Json
  holders     Json   @default("[]")

  @@index([orderId])
}

model Payment {
  id            String          @id @default(cuid())
  orderId       String
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider      PaymentProvider
  status        PaymentStatus   @default(PENDING)
  amountGel     Int
  bankPaymentId String?         @unique
  redirectUrl   String          @default("")
  rawCreate     Json?
  rawCallback   Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([orderId])
  @@index([status])
}

model ClubEvent {
  id          String            @id @default(cuid())
  slug        String            @unique
  title       String
  about       String            @default("")
  imagePath   String            @default("")
  lineup      String            @default("")
  tag         String            @default("")
  dayLabel    String
  dateLabel   String
  eventDate   String?
  accent      String            @default("#c8ff00")
  priceGel    Int               @default(45)
  isFeatured  Boolean           @default(false)
  published   Boolean           @default(true)
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  ticketTiers EventTicketTier[]

  @@index([published, sortOrder])
}

model EventTicketTier {
  id        String    @id @default(cuid())
  eventId   String
  event     ClubEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sortOrder Int       @default(0)
  label     String    @default("")
  quantity  Int
  priceGel  Int

  @@index([eventId, sortOrder])
}

model SiteSetting {
  key   String @id
  value String
}

model Ticket {
  id               String       @id @default(cuid())
  qrToken          String       @unique
  userId           String
  user             User         @relation("TicketOwner", fields: [userId], references: [id], onDelete: Cascade)
  createdByUserId  String?
  createdBy        User?        @relation("TicketCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  productSlug      String
  productName      String
  eventDate        String?
  priceGel         Int
  tierLabel        String       @default("")
  holderFirstName  String
  holderLastName   String
  holderPersonalId String
  holderEmail      String
  holderPhone      String
  status           TicketStatus @default(VALID)
  source           TicketSource
  scannedAt        DateTime?
  createdAt        DateTime     @default(now())

  @@index([userId])
  @@index([createdByUserId])
  @@index([productSlug])
  @@index([createdAt])
}
