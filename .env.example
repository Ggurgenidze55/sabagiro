# PostgreSQL (Railway / Neon / local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sabagiro"

# Session signing (min 16 chars) — openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Public site URL (QR links + emails)
APP_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# Email (Resend — tickets + contact form)
RESEND_API_KEY=""
EMAIL_FROM="Sabagiro <info@sabagiro.ge>"
# Contact form inbox (defaults to info@sabagiro.ge)
# CONTACT_INBOX_EMAIL="info@sabagiro.ge"

# Apple Wallet (.pkpass) — optional; see docs/WALLET.md
# APPLE_WALLET_PASS_TYPE_ID="pass.ge.sabagiro.ticket"
# APPLE_WALLET_TEAM_ID=""
# APPLE_WALLET_WWDR_CERT=""
# APPLE_WALLET_SIGNER_CERT=""
# APPLE_WALLET_SIGNER_KEY=""
# APPLE_WALLET_SIGNER_KEY_PASSPHRASE=""

# Analytics & SEO — see docs/SEO.md
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_META_PIXEL_ID=123456789012345
# GOOGLE_SITE_VERIFICATION=google-site-verification-code

# First admin (run: npm run seed:admin — local only)
ADMIN_EMAIL="info@sabagiro.ge"
ADMIN_PASSWORD="change-me-strong-password"
ADMIN_PHONE="+995500000000"
ADMIN_FIRST_NAME="Admin"
ADMIN_LAST_NAME="Sabagiro"
ADMIN_PERSONAL_ID="00000000000"
